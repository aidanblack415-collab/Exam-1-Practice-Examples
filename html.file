)

q(
"""<b>60.</b> If you receive an order that conflicts with a previous order or a written directive, the best practice is to:""",
[
    "Ignore the new order",
    "Follow whichever order you prefer",
    "Respectfully call attention to the conflict of orders",
    "Do nothing and document later"
],
2,
"Per your notes: employees should promptly obey lawful orders; if an order conflicts with a prior order or written directive, respectfully call attention to the conflict.",
"Non-Legal"
)

assert len(questions) == 60

# HTML template with JS for shuffling choices but keeping answer mapping.
html_doc = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>USCP Practice Test (60 Questions) — Hard Mode</title>
  <style>
    :root {{
      --bg: #0b1220;
      --panel: #101a33;
      --panel2: #0e1730;
      --text: #e8eefc;
      --muted: #a9b6da;
      --accent: #7aa2ff;
      --good: #24c36a;
      --bad: #ff5c74;
      --warn: #ffd166;
      --border: rgba(255,255,255,.12);
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0; padding: 24px;
      background: radial-gradient(1200px 600px at 20% 0%, rgba(122,162,255,.18), transparent 55%),
                  radial-gradient(900px 500px at 80% 10%, rgba(36,195,106,.12), transparent 60%),
                  var(--bg);
      color: var(--text);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      line-height: 1.45;
    }}
    .wrap {{ max-width: 980px; margin: 0 auto; }}
    header {{
      display: flex; flex-wrap: wrap; gap: 12px;
      align-items: center; justify-content: space-between;
      margin-bottom: 18px;
    }}
    h1 {{
      font-size: 22px; margin: 0;
      letter-spacing: .2px;
    }}
    .meta {{
      color: var(--muted);
      font-size: 13px;
    }}
    .card {{
      border: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(16,26,51,.92), rgba(14,23,48,.92));
      border-radius: 14px;
      padding: 16px;
      box-shadow: 0 10px 28px rgba(0,0,0,.35);
      margin-bottom: 14px;
    }}
    .controls {{
      display: flex; flex-wrap: wrap; gap: 10px;
      align-items: center; justify-content: space-between;
      margin: 14px 0 10px;
    }}
    button {{
      background: rgba(122,162,255,.18);
      color: var(--text);
      border: 1px solid rgba(122,162,255,.35);
      padding: 10px 12px;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 600;
    }}
    button:hover {{ background: rgba(122,162,255,.26); }}
    button:disabled {{
      opacity: .55;
      cursor: not-allowed;
    }}
    .pill {{
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 13px;
      background: rgba(255,255,255,.04);
    }}
    .grid {{
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }}
    .qhead {{
      display: flex;
      gap: 10px;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }}
    .tag {{
      font-size: 12px;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--muted);
      background: rgba(255,255,255,.03);
      white-space: nowrap;
    }}
    .prompt {{
      font-size: 15px;
      color: var(--text);
    }}
    .choices {{
      margin-top: 10px;
      display: grid;
      gap: 8px;
    }}
    label.choice {{
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 10px 10px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,.03);
      cursor: pointer;
    }}
    label.choice:hover {{
      background: rgba(255,255,255,.06);
    }}
    input[type="radio"] {{
      margin-top: 3px;
      transform: scale(1.05);
    }}
    .letter {{
      width: 26px; height: 26px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center; justify-content: center;
      background: rgba(122,162,255,.16);
      border: 1px solid rgba(122,162,255,.28);
      font-weight: 800;
      flex: 0 0 auto;
    }}
    .explain {{
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(0,0,0,.18);
      color: var(--muted);
      display: none;
    }}
    .explain.good {{
      border-color: rgba(36,195,106,.55);
      background: rgba(36,195,106,.10);
      color: #c8f5dc;
    }}
    .explain.bad {{
      border-color: rgba(255,92,116,.55);
      background: rgba(255,92,116,.08);
      color: #ffd0d8;
    }}
    .footer {{
      color: var(--muted);
      font-size: 12px;
      margin-top: 10px;
    }}
    .small {{
      font-size: 12px;
      color: var(--muted);
    }}
    .topnote {{
      color: var(--muted);
      font-size: 13px;
      margin-top: 6px;
    }}
    .score {{
      font-size: 14px;
      color: var(--text);
      font-weight: 700;
    }}
  </style>
</head>
<body>
<div class="wrap">
  <header>
    <div>
      <h1>USCP Practice Test (60 Questions) — Hard Mode</h1>
      <div class="topnote">30 legal scenario questions (best charge) + 30 knowledge/policy questions. Choices are randomized per question each time you load.</div>
    </div>
    <div class="pill" id="statusPill">Not submitted</div>
  </header>

  <div class="card">
    <div class="controls">
      <div class="pill"><span>🧠</span><span><b>Tip:</b> For scenario items, several answers may fit elements—pick the <b>best / primary / highest</b> charge.</span></div>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="btnSubmit">Submit & Grade</button>
        <button id="btnReset">Reset</button>
      </div>
    </div>
    <div class="score" id="scoreLine">Score: —</div>
    <div class="small" id="breakdownLine">Legal: — | Non-Legal: —</div>
  </div>

  <div id="quiz" class="grid"></div>

  <div class="footer">
    Built as a single-file HTML test for GitHub Pages. No external libraries required.
  </div>
</div>

<script>
const QUESTIONS = {json.dumps(questions)};

function shuffle(arr) {{
  for (let i = arr.length - 1; i > 0; i--) {{
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }}
  return arr;
}}

function renderQuiz() {{
  const quiz = document.getElementById('quiz');
  quiz.innerHTML = '';

  QUESTIONS.forEach((q, idx) => {{
    // Create a shuffled choice order, but keep track of which choice is correct after shuffle
    const choiceObjs = q.choices.map((text, i) => ({{ text, originalIndex: i }}));
    shuffle(choiceObjs);

    const correctOriginal = q.correct;
    const correctShuffledIndex = choiceObjs.findIndex(c => c.originalIndex === correctOriginal);

    // Store mapping for grading
    q._shuffled = choiceObjs;
    q._correctShuffled = correctShuffledIndex;

    const card = document.createElement('div');
    card.className = 'card';
    card.id = `q_${idx}`;

    const head = document.createElement('div');
    head.className = 'qhead';

    const prompt = document.createElement('div');
    prompt.className = 'prompt';
    prompt.innerHTML = q.prompt;

    const tag = document.createElement('div');
    tag.className = 'tag';
    tag.textContent = q.category;

    head.appendChild(tag);
    card.appendChild(head);
    card.appendChild(prompt);

    const choices = document.createElement('div');
    choices.className = 'choices';

    const letters = ['A','B','C','D'];

    choiceObjs.forEach((c, ci) => {{
      const id = `q${idx}_c${ci}`;
      const label = document.createElement('label');
      label.className = 'choice';
      label.setAttribute('for', id);

      const radio = document.createElement('input');
      radio.type = 'radio';
      radio.name = `q${idx}`;
      radio.id = id;
      radio.value = String(ci);

      const letter = document.createElement('div');
      letter.className = 'letter';
      letter.textContent = letters[ci];

      const text = document.createElement('div');
      text.innerHTML = c.text;

      label.appendChild(radio);
      label.appendChild(letter);
      label.appendChild(text);
      choices.appendChild(label);
    }});

    card.appendChild(choices);

    const explain = document.createElement('div');
    explain.className = 'explain';
    explain.id = `exp_${idx}`;
    explain.innerHTML = q.explanation;
    card.appendChild(explain);

    quiz.appendChild(card);
  }});
}}

function grade() {{
  let correct = 0;
  let correctLegal = 0;
  let correctNon = 0;
  let totalLegal = 0;
  let totalNon = 0;

  QUESTIONS.forEach((q, idx) => {{
    const isLegal = q.category === "Legal";
    if (isLegal) totalLegal++; else totalNon++;

    const radios = document.getElementsByName(`q${idx}`);
    let chosen = -1;
    for (const r of radios) {{
      if (r.checked) {{ chosen = parseInt(r.value, 10); break; }}
    }}

    const exp = document.getElementById(`exp_${idx}`);
    exp.style.display = 'block';

    if (chosen === q._correctShuffled) {{
      correct++;
      if (isLegal) correctLegal++; else correctNon++;
      exp.classList.remove('bad');
      exp.classList.add('good');
      exp.innerHTML = "<b>Correct.</b> " + q.explanation;
    }} else {{
      exp.classList.remove('good');
      exp.classList.add('bad');

      const letters = ['A','B','C','D'];
      const correctLetter = letters[q._correctShuffled];
      const correctText = q._shuffled[q._correctShuffled].text;
      const chosenText = (chosen >= 0 && chosen < 4) ? q._shuffled[chosen].text : "<i>No answer selected</i>";

      exp.innerHTML =
        "<b>Incorrect.</b> " +
        "<div style='margin-top:6px'><b>Your answer:</b> " + chosenText + "</div>" +
        "<div style='margin-top:6px'><b>Best answer (" + correctLetter + "):</b> " + correctText + "</div>" +
        "<div style='margin-top:8px'>" + q.explanation + "</div>";
    }}
  }});

  const pct = Math.round((correct / QUESTIONS.length) * 100);
  document.getElementById('scoreLine').textContent = `Score: ${correct}/${QUESTIONS.length} (${pct}%)`;
  document.getElementById('breakdownLine').textContent =
    `Legal: ${correctLegal}/${totalLegal} | Non-Legal: ${correctNon}/${totalNon}`;

  const pill = document.getElementById('statusPill');
  pill.textContent = `Submitted • ${pct}%`;
}}

function resetQuiz() {{
  // Rerender to reshuffle choices and clear selections/explanations
  renderQuiz();
  document.getElementById('scoreLine').textContent = "Score: —";
  document.getElementById('breakdownLine').textContent = "Legal: — | Non-Legal: —";
  const pill = document.getElementById('statusPill');
  pill.textContent = "Not submitted";
}}

document.getElementById('btnSubmit').addEventListener('click', grade);
document.getElementById('btnReset').addEventListener('click', resetQuiz);

renderQuiz();
</script>
</body>
</html>
"""

out_path.write_text(html_doc, encoding="utf-8")
str(out_path)
