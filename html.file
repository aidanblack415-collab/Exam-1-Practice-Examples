from pathlib import Path
import random, html, json, textwrap

out_path = Path("/mnt/data/uscp_practice_test_60q_harder.html")

# Build question bank
# Each question: {id, category, prompt_html, choices:[...], correct_index, explanation}
questions = []

def q(prompt, choices, correct, explanation, category):
    questions.append({
        "category": category,
        "prompt": prompt.strip(),
        "choices": choices,
        "correct": correct,
        "explanation": explanation.strip()
    })

# -------------------------
# LEGAL SCENARIO QUESTIONS (30)
