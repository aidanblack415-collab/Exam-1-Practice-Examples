"Non-Legal"
)

q(
"""<b>56.</b> The USCP Board consists of:""",
[
    "House and Senate Sergeant at Arms, Architect of the Capitol, and Chief of Police",
    "Only the Chief of Police and Inspector General",
    "The President, Vice President, and Speaker",
    "House Sergeant at Arms, Senate Sergeant at Arms, and OIG only"
],
0,
